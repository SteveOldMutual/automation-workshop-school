<div class="tile">
    <div class="tile-body">
        <h5 class="tile-title">@Title</h5>
        <p class="tile-text">@Number</p>
    </div>
</div>

<style>
    .tile {
        border: 1px solid #ccc;
        border-radius: 8px;
        padding: 16px;
        width: 150px;
        text-align: center;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        transition: transform 0.2s;
    }

        .tile:hover {
            transform: scale(1.05);
        }

    .tile-body {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .tile-title {
        font-size: 1.25rem;
        margin-bottom: 8px;
    }

    .tile-text {
        font-size: 1.5rem;
        font-weight: bold;
    }
</style>

@code {
    [Parameter]
    public string Title { get; set; }

    [Parameter]
    public int Number { get; set; }
}